# Target Platform
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y

# 仅启用 ZN-M2 设备
CONFIG_TARGET_DEVICE_qualcommax_ipq60xx_DEVICE_zn_m2=y

# 编译优化
CONFIG_CCACHE=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_TARGET_ROOTFS_INITRAMFS=n

# 内核配置（显式禁用 USB/存储）
CONFIG_USB_SUPPORT=n
CONFIG_USB=n

# 禁用WIFI驱动
CONFIG_WIRELESS=n
CONFIG_CFG80211=n
CONFIG_MAC80211=n
CONFIG_PACKAGE_kmod-ath11k=n
CONFIG_PACKAGE_kmod-ath11k-ahb=n
CONFIG_PACKAGE_kmod-ath11k-pci=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018=n
CONFIG_PACKAGE_ath11k-firmware-ipq6018-ddwrt=n
CONFIG_PACKAGE_kmod-cfg80211=n
CONFIG_PACKAGE_kmod-mac80211=n
CONFIG_PACKAGE_iw=n
CONFIG_PACKAGE_hostapd-common=n
CONFIG_PACKAGE_wpad-openssl=n

# USB 驱动禁用
CONFIG_PACKAGE_kmod-usb-core=n

# 文件系统禁用
CONFIG_PACKAGE_kmod-fs-ext4=n
CONFIG_PACKAGE_kmod-fs-vfat=n

# 移除所有存储工具
CONFIG_PACKAGE_automount=n
CONFIG_PACKAGE_block-mount=n
CONFIG_PACKAGE_containerd=n
CONFIG_PACKAGE_cgroupfs-mount=n
CONFIG_PACKAGE_e2fsprogs=n
CONFIG_PACKAGE_iwinfo=n
CONFIG_PACKAGE_mkf2fs=n
CONFIG_PACKAGE_mount-utils=n
CONFIG_PACKAGE_ntfs3-mount=n
CONFIG_PACKAGE_mqttled=n
CONFIG_PACKAGE_blkid=n
CONFIG_PACKAGE_fdisk=n
CONFIG_PACKAGE_lsblk=n

# 设置中文语言
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# 主题配置 - 只保留 material 主题
CONFIG_PACKAGE_luci-theme-material=y
CONFIG_PACKAGE_luci-theme-argon=n
CONFIG_PACKAGE_luci-theme-argon-dark=n
CONFIG_PACKAGE_luci-theme-bootstrap=n
CONFIG_PACKAGE_luci-theme-openwrt=n
CONFIG_PACKAGE_luci-theme-openwrt-2020=n
CONFIG_PACKAGE_luci-theme-argon_IMAGES=n
CONFIG_PACKAGE_luci-theme-argon_SELECTED=n

# SSR-Plus 配置 - 只启用 SingBox
CONFIG_PACKAGE_luci-app-ssr-plus=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_SingBox=y
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Xray=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Hysteria=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_MosDNS=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_NaiveProxy=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Simple_Obfs=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_ShadowsocksR_Libev_Client=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_ShadowsocksR_Libev_Server=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Rust_Client=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Shadowsocks_Rust_Server=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Trojan_GO=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_Trojan_Plus=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_tuic_client=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_V2ray_Plugin=n
CONFIG_PACKAGE_luci-app-ssr-plus_INCLUDE_WireGuard=n

# 禁用 WireGuard
CONFIG_PACKAGE_kmod-wireguard=n
CONFIG_PACKAGE_wireguard-tools=n

# LuCI 应用
CONFIG_PACKAGE_luci-app-easytier=y
CONFIG_PACKAGE_luci-app-cpufreq=y
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-app-wolplus=y

# 删除的应用
CONFIG_PACKAGE_luci-app-homeproxy=n
CONFIG_PACKAGE_luci-app-attendedsysupgrade=n
CONFIG_PACKAGE_luci-app-wol=n
